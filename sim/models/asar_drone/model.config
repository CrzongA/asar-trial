<?xml version="1.0"?>
<model>
  <name>asar_drone</name>
  <version>1.0</version>
  <sdf version="1.10">model.sdf</sdf>
  <author>
    <name>ASAR</name>
    <email>noreply@asar.local</email>
  </author>
  <description>
    ASAR project drone: thin wrapper around PX4's stock x500_gimbal airframe.
    Exists to give us a single place to attach extra sensors (thermal, depth,
    lidar) without forking PX4-Autopilot. Add new &lt;sensor&gt; blocks in model.sdf.
  </description>
</model>
